{
  "name": "stexpedite-press",
  "private": true,
  "license": "UNLICENSED",
  "type": "module",
  "scripts": {
    "identity:build": "python scripts/generate-identity-assets.py",
    "build": "npm --prefix apps/web run build",
    "build:web": "npm --prefix apps/web run build",
    "build:rice": "cd apps/rice && python scripts/build_public_site.py",
    "build:all": "npm run build:web && npm run build:rice",
    "dev:web": "npm --prefix apps/web run dev",
    "dev:rice": "cd apps/rice && python -m http.server 4173",
    "dev:worker": "node scripts/dev-worker.mjs",
    "run:bash": "node scripts/run-bash.mjs",
    "sync:worker-dev-vars": "node scripts/sync-worker-dev-vars.mjs",
    "bootstrap:venv": "node scripts/run-bash.mjs scripts/bootstrap-python-venv.sh",
    "assets:sync": "node scripts/run-bash.mjs scripts/sync-assets.sh",
    "assets:check": "node scripts/run-bash.mjs scripts/check-assets-sync.sh",
    "lint:html": "npx -y htmlhint \"apps/web/dist/**/*.html\"",
    "check:links": "node scripts/check-links.mjs",
    "check:a11y": "node scripts/check-a11y.mjs",
    "check:rice": "cd apps/rice && python scripts/check_assets.py",
    "check:docs": "node scripts/check-docs-coverage.mjs",
    "check:lighthouse": "node scripts/check-lighthouse.mjs",
    "check:seo": "node scripts/run-bash.mjs scripts/check-site-seo.sh",
    "check:audit": "npm audit --audit-level=high && npm --prefix apps/web audit --audit-level=high && npm --prefix apps/communications-worker audit --audit-level=high",
    "runtime:config": "node scripts/run-bash.mjs scripts/check-runtime-config.sh",
    "runtime:audit": "node scripts/run-bash.mjs ops/cloudflare-stability/scripts/runtime-audit.sh",
    "smoke:api": "node scripts/run-bash.mjs ops/cloudflare-stability/scripts/smoke-api.sh",
    "smoke:api:full": "node scripts/run-bash.mjs ops/cloudflare-stability/scripts/smoke-api.sh --full",
    "release": "node scripts/run-bash.mjs scripts/release.sh",
    "release:dry-run": "node scripts/run-bash.mjs scripts/release.sh --dry-run",
    "release:log": "node scripts/run-bash.mjs ops/cloudflare-stability/scripts/log-release-evidence.sh",
    "test:worker": "npm --prefix apps/communications-worker run test",
    "check": "npm run check:docs && npm run build && npm run lint:html && npm run check:links && npm run check:a11y && npm run test:worker && npm run check:audit",
    "deploy:web": "node scripts/deploy-web.mjs",
    "deploy:rice": "npm run build:rice && npx wrangler pages deploy apps/rice/_site --project-name=rice-magazine --branch=main --commit-dirty=true",
    "deploy:all": "npm run deploy:web && npm run deploy:rice",
    "deploy:worker": "npm --prefix apps/communications-worker run deploy"
  },
  "devDependencies": {
    "@playwright/mcp": "^0.0.70"
  }
}
