{
  "name": "stexpedite-press",
  "private": true,
  "license": "UNLICENSED",
  "type": "module",
  "scripts": {
    "build": "npm --prefix apps/web run build",
    "dev:web": "npm --prefix apps/web run dev",
    "dev:worker": "node scripts/dev-worker.mjs",
    "run:bash": "node scripts/run-bash.mjs",
    "sync:worker-dev-vars": "node scripts/sync-worker-dev-vars.mjs",
    "bootstrap:venv": "node scripts/run-bash.mjs internal/agent/tools/bootstrap-python-venv.sh",
    "assets:sync": "node scripts/run-bash.mjs internal/agent/tools/sync-assets.sh",
    "assets:check": "node scripts/run-bash.mjs internal/agent/tools/check-assets-sync.sh",
    "lint:html": "npx -y htmlhint \"apps/web/dist/**/*.html\"",
    "check:links": "node scripts/check-links.mjs",
    "check:a11y": "node scripts/check-a11y.mjs",
    "check:lighthouse": "node scripts/check-lighthouse.mjs",
    "check:seo": "node scripts/run-bash.mjs internal/agent/tools/check-site-seo.sh",
    "runtime:config": "node scripts/run-bash.mjs internal/agent/tools/check-runtime-config.sh",
    "runtime:audit": "node scripts/run-bash.mjs internal/agent/skills/ops/cloudflare-stability/scripts/runtime-audit.sh",
    "smoke:api": "node scripts/run-bash.mjs internal/agent/skills/ops/cloudflare-stability/scripts/smoke-api.sh",
    "smoke:api:full": "node scripts/run-bash.mjs internal/agent/skills/ops/cloudflare-stability/scripts/smoke-api.sh --full",
    "release": "node scripts/run-bash.mjs internal/agent/tools/release.sh",
    "release:dry-run": "node scripts/run-bash.mjs internal/agent/tools/release.sh --dry-run",
    "release:log": "node scripts/run-bash.mjs internal/agent/skills/ops/cloudflare-stability/scripts/log-release-evidence.sh",
    "test:worker": "npm --prefix apps/communications-worker run test",
    "check": "npm run build && npm run lint:html && npm run check:links && npm run check:a11y && npm run test:worker",
    "deploy:web": "node scripts/deploy-web.mjs",
    "deploy:worker": "npm --prefix apps/communications-worker run deploy"
  },
  "devDependencies": {
    "@playwright/mcp": "^0.0.70"
  }
}
