{
  "repo": {
    "name": "stexpedite-press",
    "license": "proprietary",
    "agent_instructions": {
      "canonical": "agent/AGENT.md",
      "claude_entrypoint": "CLAUDE.md",
      "repo_skills": "agent/skills/",
      "ops_runbooks": "agent/ops/",
      "tools": "agent/tools/",
      "kits": "agent/kits/"
    }
  },
  "apps": {
    "web": {
      "dir": "apps/web/",
      "source_dir": "apps/web/src/",
      "assets_dir": "apps/web/public/assets/",
      "output_dir": "apps/web/dist/",
      "build_script": "npm run build",
      "css_tokens": "apps/web/public/assets/css/tokens.css",
      "site_data": "apps/web/src/data/site.json",
      "routes": {
        "/": { "file": "apps/web/src/pages/index.astro", "brand_mode": "ritual" },
        "/books": { "file": "apps/web/src/pages/books.astro", "brand_mode": "editorial" },
        "/about": { "file": "apps/web/src/pages/about.astro", "brand_mode": "editorial" },
        "/contact": { "file": "apps/web/src/pages/contact.astro", "brand_mode": "utility" },
        "/donate": { "file": "apps/web/src/pages/donate.astro", "brand_mode": "utility" },
        "/donate/thanks": { "file": "apps/web/src/pages/donate/thanks.astro", "brand_mode": "utility" },
        "/submit": { "file": "apps/web/src/pages/submit.astro", "brand_mode": "utility" },
        "/gallery": { "file": "apps/web/src/pages/gallery.astro", "brand_mode": "editorial" },
        "/lab": { "file": "apps/web/src/pages/lab.astro", "brand_mode": "ritual" },
        "/services": { "file": "apps/web/src/pages/services.astro", "brand_mode": "editorial" }
      }
    },
    "communications_worker": {
      "dir": "apps/communications-worker/",
      "implementation": "apps/communications-worker/src/index.ts",
      "openapi": "apps/communications-worker/openapi.yaml",
      "wrangler_config": "apps/communications-worker/wrangler.toml",
      "migrations": "apps/communications-worker/migrations/",
      "tests": "apps/communications-worker/test/index.test.ts",
      "routes": {
        "GET /api/health": "runtime health and dependency flags",
        "GET /api/storefront": "Fourthwall storefront catalog",
        "GET /api/projects": "D1-backed projects catalog",
        "POST /api/contact": "contact form email and D1 log",
        "POST /api/submit": "submission inquiry email and D1 log",
        "POST /api/donate/session": "Stripe Checkout session creation",
        "POST /api/updates": "updates signup capture",
        "POST /api/updates/import": "token-gated updates enrichment import",
        "POST /api/updates/unsubscribe": "updates unsubscribe marker"
      }
    }
  },
  "assets": {
    "source": "assets/source/",
    "published": "apps/web/public/assets/",
    "manifest": "assets/manifest.txt",
    "sync": "npm run assets:sync",
    "check": "npm run assets:check",
    "files": {
      "crow_glitch_text_still.webp": "portal still — primary OG image",
      "crow_glitch_text_still.png": "PNG browser fallback",
      "crow_glitch_text.webp": "animated portal (JS-swapped)",
      "crow_glitch_text.gif": "source animated gif",
      "void_engine_twinkle_green.webp": "background texture (preferred)",
      "void_engine_twinkle_green.png": "background texture fallback",
      "favicon.svg": "browser favicon",
      "les-fievres-cover.svg": "book cover",
      "covers/lift-wind-cover.jpg": "book cover — needs webp variant"
    }
  },
  "branding": {
    "dir": "branding/",
    "overview": "branding/README.md",
    "assessment": "branding/ux-assessment.md",
    "guidelines": "branding/brand-guidelines.md",
    "web_elements": "branding/web-elements.md",
    "tokens": [
      "branding/tokens/brand-tokens.json",
      "branding/tokens/brand-tokens.css"
    ],
    "asset_handoff": "branding/assets/README.md",
    "export_manifest": "branding/export-manifest.json",
    "scope": "exportable design-system documentation and token guidance; no runtime behavior; live tokens are in apps/web/public/assets/css/tokens.css"
  },
  "commands": {
    "build": "npm run build",
    "check": "npm run check",
    "dev_web": "npm run dev:web",
    "dev_worker": "npm run dev:worker",
    "test_worker": "npm run test:worker",
    "deploy_web": "npm run deploy:web",
    "deploy_worker": "npm run deploy:worker",
    "assets_sync": "npm run assets:sync",
    "assets_check": "npm run assets:check",
    "runtime_config": "npm run runtime:config",
    "runtime_audit": "npm run runtime:audit",
    "smoke_api": "npm run smoke:api",
    "release_dry_run": "npm run release:dry-run",
    "release": "npm run release"
  },
  "docs": {
    "root": "README.md",
    "deployment": "DEPLOYMENT.md",
    "state": "docs/state-of-play.md",
    "operations": "docs/operations/",
    "infrastructure": "docs/infrastructure/",
    "ontology": "docs/ontology/"
  },
  "agent": {
    "dir": "agent/",
    "canonical_instructions": "agent/AGENT.md",
    "skills": "agent/skills/",
    "ops": "agent/ops/",
    "tools": "agent/tools/",
    "kits": "agent/kits/"
  },
  "archive": {
    "dirs": [
      "archive/anglossic_quiz/"
    ],
    "status": "non-live historical product material; removed legacy static output is recoverable from git history"
  },
  "maintenance": {
    "when_changing_site_routes_or_assets": [
      "README.md",
      "docs/state-of-play.md",
      "docs/ontology/project-ontology.json",
      "agent/AGENT.md",
      "apps/web/src/README.pages.md"
    ],
    "when_changing_worker_routes_or_contracts": [
      "apps/communications-worker/openapi.yaml",
      "apps/communications-worker/README.md",
      "docs/infrastructure/",
      "docs/ontology/project-ontology.json",
      "agent/AGENT.md"
    ],
    "when_changing_css_tokens": [
      "apps/web/public/assets/css/tokens.css",
      "branding/tokens/",
      "agent/AGENT.md"
    ],
    "when_changing_agent_workflows": [
      "agent/AGENT.md",
      "CLAUDE.md",
      "docs/state-of-play.md",
      "docs/ontology/project-ontology.json"
    ]
  }
}
