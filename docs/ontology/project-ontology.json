{
  "repo": {
    "name": "stexpedite-press",
    "license": "proprietary",
    "agent_instructions": {
      "canonical": "AGENTS.md",
      "claude_entrypoint": "CLAUDE.md",
      "repo_skills": "skills/",
      "ops_runbooks": "ops/",
      "tools": "scripts/",
      "kits": "kits/"
    }
  },
  "apps": {
    "web": {
      "dir": "apps/web/",
      "source_dir": "apps/web/src/",
      "assets_dir": "apps/web/public/assets/",
      "output_dir": "apps/web/dist/",
      "build_script": "npm run build",
      "deploy_script": "npm run deploy:web",
      "deploy_auth": {
        "required_env": [
          "CLOUDFLARE_API_TOKEN",
          "CLOUDFLARE_ACCOUNT_ID"
        ],
        "optional_env": [
          "CF_PAGES_PROJECT"
        ],
        "ci_secrets": [
          "CLOUDFLARE_API_TOKEN",
          "CLOUDFLARE_ACCOUNT_ID"
        ]
      },
      "css_tokens": "apps/web/public/assets/css/tokens.css",
      "site_data": "apps/web/src/data/site.json",
      "routes": {
        "/": { "file": "apps/web/src/pages/index.astro", "brand_mode": "ritual" },
        "/books": { "file": "apps/web/src/pages/books.astro", "brand_mode": "editorial" },
        "/about": { "file": "apps/web/src/pages/about.astro", "brand_mode": "editorial" },
        "/contact": { "file": "apps/web/src/pages/contact.astro", "brand_mode": "utility" },
        "/donate": { "file": "apps/web/src/pages/donate.astro", "brand_mode": "utility" },
        "/donate/thanks": { "file": "apps/web/src/pages/donate/thanks.astro", "brand_mode": "utility" },
        "/submit": { "file": "apps/web/src/pages/submit.astro", "brand_mode": "utility" },
        "/gallery": { "file": "apps/web/src/pages/gallery.astro", "brand_mode": "editorial" },
        "/lab": { "file": "apps/web/src/pages/lab.astro", "brand_mode": "ritual" },
        "/services": { "file": "apps/web/src/pages/services.astro", "brand_mode": "editorial" }
      }
    },
    "communications_worker": {
      "dir": "apps/communications-worker/",
      "implementation": "apps/communications-worker/src/index.ts",
      "openapi": "apps/communications-worker/openapi.yaml",
      "wrangler_config": "apps/communications-worker/wrangler.toml",
      "migrations": "apps/communications-worker/migrations/",
      "tests": "apps/communications-worker/test/index.test.ts",
      "routes": {
        "GET /api/health": "runtime health and dependency flags",
        "GET /api/storefront": "Fourthwall storefront catalog",
        "GET /api/projects": "D1-backed projects catalog",
        "POST /api/contact": "contact form email and D1 log",
        "POST /api/submit": "submission inquiry email and D1 log",
        "POST /api/donate/session": "Stripe Checkout session creation",
        "POST /api/stripe/webhook": "Stripe checkout completion webhook receiver",
        "POST /api/updates": "updates signup capture",
        "POST /api/updates/import": "token-gated updates enrichment import",
        "POST /api/updates/unsubscribe": "updates unsubscribe marker"
      }
    }
  },
  "assets": {
    "source": "assets/source/",
    "published": "apps/web/public/assets/",
    "generated_build": "apps/web/dist/assets/",
    "ownership": {
      "canonical_media": [
        "assets/source/img/",
        "assets/source/gif/"
      ],
      "authored_public": [
        "apps/web/public/assets/css/",
        "apps/web/public/assets/js/",
        "apps/web/public/assets/fonts/",
        "apps/web/public/assets/README.md"
      ]
    },
    "manifests": [
      "assets/manifest.json",
      "assets/manifest.txt"
    ],
    "manifest_builder": "scripts/build-asset-manifest.mjs",
    "sync": "npm run assets:sync",
    "check": "npm run assets:check",
    "files": {
      "identity/expedite-seal-source-2026.png": "preserved institutional seal source scan",
      "identity/expedite-seal-master.svg": "clean recolorable institutional seal",
      "identity/expedite-seal-distressed.svg": "distressed recolorable display seal",
      "identity/expedite-seal-motion.svg": "homepage-only layered ritual animation with reduced-motion fallback",
      "identity/expedite-seal-green-768.webp": "homepage portal seal",
      "identity/expedite-seal-og-1200x630.webp": "default social preview",
      "crow_glitch_text_still.webp": "portal still — primary OG image",
      "crow_glitch_text_still.png": "PNG browser fallback",
      "crow_glitch_text.webp": "animated portal (JS-swapped)",
      "crow_glitch_text.gif": "source animated gif",
      "void_engine_twinkle_green.webp": "background texture (preferred)",
      "void_engine_twinkle_green.png": "background texture fallback",
      "favicon.svg": "browser favicon",
      "les-fievres-cover.svg": "book cover",
      "covers/lift-wind-cover.jpg": "book cover source variant",
      "covers/lift-wind-cover.webp": "book cover optimized variant"
    }
  },
  "branding": {
    "dir": "branding/",
    "overview": "branding/README.md",
    "assessment": "branding/ux-assessment.md",
    "guidelines": "branding/brand-guidelines.md",
    "web_elements": "branding/web-elements.md",
    "tokens": [
      "branding/tokens/brand-tokens.json",
      "branding/tokens/brand-tokens.css"
    ],
    "asset_handoff": "branding/assets/README.md",
    "export_manifest": "branding/export-manifest.json",
    "scope": "exportable design-system documentation and token guidance; no runtime behavior; live tokens are in apps/web/public/assets/css/tokens.css"
  },
  "commands": {
    "build": "npm run build",
    "check": "npm run check",
    "dev_web": "npm run dev:web",
    "dev_worker": "npm run dev:worker",
    "test_worker": "npm run test:worker",
    "deploy_web": "npm run deploy:web",
    "deploy_worker": "npm run deploy:worker",
    "assets_sync": "npm run assets:sync",
    "assets_check": "npm run assets:check",
    "identity_build": "npm run identity:build",
    "tooling_integrity": "npm run check:tooling-integrity",
    "audit": "npm run check:audit",
    "runtime_config": "npm run runtime:config",
    "runtime_audit": "npm run runtime:audit",
    "smoke_api": "npm run smoke:api",
    "release_dry_run": "npm run release:dry-run",
    "release": "npm run release"
  },
  "docs": {
    "root": "README.md",
    "deployment": "DEPLOYMENT.md",
    "state": "docs/state-of-play.md",
    "operations": "docs/operations/",
    "infrastructure": "docs/infrastructure/",
    "ontology": "docs/ontology/",
    "ontology_human": "docs/ontology/ontology.md"
  },
  "agent": {
    "dir": "ops/",
    "canonical_instructions": "AGENTS.md",
    "skills": "skills/",
    "ops": "ops/",
    "tools": "scripts/",
    "kits": "kits/",
    "orchestration_policy": {
      "mode": "orchestration-first",
      "primary_agent_retains": [
        "planning and safe decomposition",
        "integration and cross-surface decisions",
        "critical blockers requiring full context",
        "conflict resolution and final validation"
      ],
      "parallelize_when": "Work can be safely decomposed into independent read, implementation, review, or validation tracks.",
      "assignment_requires": [
        "explicit scope and success criteria",
        "read-only or read/write ownership",
        "non-overlapping boundaries",
        "expected output and integration notes",
        "raw artifact locations"
      ],
      "subagent_return_requires": [
        "concise result",
        "raw verification artifacts"
      ],
      "preferred_openrouter_model": "deepseek/deepseek-v4-flash",
      "model_fallback": "If the runner cannot select or verify a custom OpenRouter model, use the available runtime model and explicitly log the fallback; never fake compliance.",
      "secrets": "Never pass secrets, environment-file contents, credentials, tokens, or unnecessary sensitive context to subagents."
    },
    "skill_generation_and_curation": {
      "sequence": [
        "inventory and search repo, installed, and available skills",
        "update or extend a suitable skill before creating a duplicate",
        "follow the skill-creator structure for new or materially revised skills",
        "validate the skill and referenced paths or scripts",
        "forward-test with fresh subagents outside the authoring context",
        "curate, consolidate, and retire or archive stale duplicate skills"
      ],
      "synchronization": [
        "AGENTS.md",
        "docs/ontology/project-ontology.json",
        "docs/ontology/ontology.md"
      ]
    }
  },
  "agent_data_dictionary": {
    "purpose": "Machine-readable definitions for the repo's documentation-driven agent tooling surface.",
    "contracts": {
      "repo_ontology": {
        "path": "docs/ontology/project-ontology.json",
        "role": "Top-level repo and agent tooling map.",
        "format": "json"
      },
      "repo_ontology_human": {
        "path": "docs/ontology/ontology.md",
        "role": "Human-readable companion to the machine ontology; update with ontology changes.",
        "format": "markdown"
      },
      "agent_guide": {
        "path": "AGENTS.md",
        "role": "Canonical human-readable operating contract for all agents.",
        "format": "markdown"
      },
      "kit_contract": {
        "path": "kits/static-web/agent.config.json",
        "role": "Machine-readable capability contract for the static-web kit.",
        "format": "json"
      },
      "worker_openapi": {
        "path": "apps/communications-worker/openapi.yaml",
        "role": "Machine-readable API contract for the communications worker.",
        "format": "openapi"
      },
      "asset_manifest": {
        "path": "assets/manifest.json",
        "role": "Generated ownership, source mapping, byte-size, and checksum inventory for published assets.",
        "format": "json"
      }
    },
    "entities": {
      "agent_instruction_surface": {
        "owner": "AGENTS.md",
        "fields": {
          "canonical": "Primary instruction document path for agents.",
          "claude_entrypoint": "Root shim that imports the canonical instructions.",
          "repo_skills": "Directory containing repo-scoped agent workflows.",
          "ops_runbooks": "Directory containing operational skills and references.",
          "tools": "Directory containing repo-owned shell tooling.",
          "kits": "Directory containing reusable agent-adjacent scaffolding."
        }
      },
      "repo_skill": {
        "owner": "skills/*",
        "required_artifacts": [
          "SKILL.md"
        ],
        "optional_artifacts": [
          "agents/openai.yaml"
        ],
        "fields": {
          "name": "Stable skill identifier.",
          "description": "When and why the skill should be used.",
          "workflow": "Ordered operator or agent procedure.",
          "guardrails": "Behavioral and safety constraints for the skill."
        }
      },
      "subagent_assignment": {
        "owner": "Primary agent under AGENTS.md orchestration policy",
        "fields": {
          "scope": "Explicit task boundary and success criteria.",
          "ownership": "Read-only or read/write files and surfaces with non-overlapping boundaries.",
          "output": "Expected result format and integration notes.",
          "raw_artifacts": "Locations of logs, reports, patches, screenshots, or other verification evidence.",
          "model": "Use deepseek/deepseek-v4-flash when custom OpenRouter selection is supported; otherwise record the available-runtime fallback.",
          "secrets": "No secrets, environment-file contents, credentials, tokens, or unnecessary sensitive context."
        }
      },
      "skill_lifecycle": {
        "owner": "AGENTS.md and skills/",
        "fields": {
          "discovery": "Inventory and search existing skills before authoring.",
          "reuse": "Update or extend before creating a duplicate.",
          "structure": "Follow the skill-creator structure.",
          "validation": "Validate instructions, metadata, referenced paths, and scripts.",
          "forward_test": "Test with fresh subagents that lack authoring context.",
          "curation": "Consolidate overlaps and retire or archive stale duplicates.",
          "ontology_sync": "Update machine and human ontology when workflows change."
        }
      },
      "ops_script": {
        "owner": "scripts/ and ops/cloudflare-stability/scripts/",
        "fields": {
          "path": "Executable shell path relative to repo root.",
          "entrypoint": "Invocation form from repo root.",
          "purpose": "Operational job the script performs.",
          "repo_root_resolution": "Must resolve repo root dynamically through scripts/lib/repo-root.sh."
        }
      },
      "command_alias": {
        "owner": "package.json scripts and Makefile targets",
        "fields": {
          "name": "Stable root command or make target name.",
          "backing_path": "Underlying script or subproject command.",
          "validation_scope": "What surface the command verifies or mutates."
        }
      },
      "kit_capability": {
        "owner": "kits/static-web/agent.config.json",
        "fields": {
          "entrypoints": "Primary executable kit commands.",
          "paths": "Canonical filesystem locations for kit assets.",
          "capabilities": "Boolean or enumerated support matrix for the kit.",
          "requires": "External tools or runtimes the kit may depend on."
        }
      }
    },
    "validation": {
      "tooling_integrity_script": "scripts/check-tooling-integrity.mjs",
      "checks": [
        "JSON parse validation for project-ontology.json and agent.config.json",
        "Existence check for ontology.md",
        "API route parity checks across Worker source, OpenAPI, docs, and ontology",
        "OpenAPI readability check for apps/communications-worker/openapi.yaml",
        "Existence checks for shell-backed root scripts and Make targets",
        "Existence checks for agent kit entrypoints and declared paths",
        "Asset ownership and checksum validation through npm run assets:check",
        "Stale-reference scan for deprecated agent path conventions"
      ]
    }
  },
  "archive": {
    "dirs": [
      "archive/anglossic_quiz/"
    ],
    "status": "non-live historical product material; removed legacy static output is recoverable from git history"
  },
  "maintenance": {
    "when_changing_site_routes_or_assets": [
      "README.md",
      "docs/state-of-play.md",
      "docs/ontology/ontology.md",
      "docs/ontology/project-ontology.json",
      "AGENTS.md",
      "apps/web/src/README.pages.md"
    ],
    "when_changing_worker_routes_or_contracts": [
      "apps/communications-worker/openapi.yaml",
      "apps/communications-worker/README.md",
      "docs/infrastructure/",
      "docs/ontology/ontology.md",
      "docs/ontology/project-ontology.json",
      "AGENTS.md"
    ],
    "when_changing_css_tokens": [
      "apps/web/public/assets/css/tokens.css",
      "branding/tokens/",
      "AGENTS.md"
    ],
    "when_changing_agent_workflows": [
      "AGENTS.md",
      "CLAUDE.md",
      "docs/state-of-play.md",
      "docs/ontology/ontology.md",
      "docs/ontology/project-ontology.json"
    ],
    "when_changing_skills_or_orchestration": [
      "AGENTS.md",
      "skills/",
      "docs/ontology/ontology.md",
      "docs/ontology/project-ontology.json"
    ],
    "when_changing_agent_data_dictionary": [
      "docs/ontology/project-ontology.json",
      "docs/ontology/ontology.md",
      "docs/ontology/README.md",
      "scripts/check-tooling-integrity.mjs"
    ]
  }
}
