---
import { ClientRouter } from 'astro:transitions';
import siteData from '../data/site.json';

interface Props {
  title: string;
  description: string;
  canonical: string;
  styles?: string[];
  robots?: string;
  ogTitle?: string;
  ogDescription?: string;
  pageTitle?: string;
}

const {
  title,
  description,
  canonical,
  styles = [],
  robots = 'index,follow,max-snippet:-1,max-image-preview:large,max-video-preview:-1',
  ogTitle,
  ogDescription,
  pageTitle,
} = Astro.props;
const { site } = siteData;
const resolvedOgTitle = ogTitle ?? `${title} \u2014 ${site.name}`;
const resolvedOgDescription = ogDescription ?? description;
const resolvedPageTitle = pageTitle ?? `${title} \u2014 ${site.name}`;
---
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="description" content={description} />
  <meta name="theme-color" content={site.themeColor} />
  <meta name="color-scheme" content="dark" />
  <meta property="og:site_name" content={site.name} />
  <meta property="og:type" content="website" />
  <meta property="og:title" content={resolvedOgTitle} />
  <meta property="og:description" content={resolvedOgDescription} />
  <meta property="og:url" content={canonical} />
  <meta property="og:image" content={site.ogImage} />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={resolvedOgTitle} />
  <meta name="twitter:description" content={resolvedOgDescription} />
  <meta name="twitter:image" content={site.ogImage} />
  <meta name="robots" content={robots} />
  <link rel="canonical" href={canonical} />
  <title>{resolvedPageTitle}</title>
  <link rel="icon" href={`/${site.favicon}`} type="image/svg+xml" />
  <link href={site.fontStylesheet} rel="stylesheet" />
  <link rel="stylesheet" href="/assets/css/hero-bar.css" />
  {styles.map(href => <link rel="stylesheet" href={`/${href}`} />)}
  <slot name="head-extra" />
  <ClientRouter />
</head>
