---
import siteData from '../data/site.json';

interface Props {
  currentNav?: string;
}

const { currentNav } = Astro.props;
const { site } = siteData;
---
<header class="site-header">
  <a class="site-wordmark" href="/">{site.name}</a>
  <nav class="site-nav" aria-label="Primary">
    {site.nav.map(item => (
      <a href={item.href} data-nav={item.group} aria-current={item.href === currentNav ? 'page' : undefined}>{item.label}</a>
    ))}
  </nav>
  <details class="site-nav-mobile">
    <summary>Menu</summary>
    <nav aria-label="Primary mobile">
      {site.nav.map(item => (
        <a href={item.href} data-nav={item.group} aria-current={item.href === currentNav ? 'page' : undefined}>{item.label}</a>
      ))}
    </nav>
  </details>
</header>
