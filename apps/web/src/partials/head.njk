<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="description" content="{{ page.description }}" />
  <meta name="theme-color" content="{{ site.themeColor }}" />
  <meta name="color-scheme" content="dark" />
  <meta property="og:site_name" content="{{ site.name }}" />
  <meta property="og:type" content="website" />
  <meta property="og:title" content="{{ page.title }} &mdash; {{ site.name }}" />
  <meta property="og:description" content="{{ page.description }}" />
  <meta property="og:url" content="{{ page.canonical }}" />
  <meta property="og:image" content="{{ site.ogImage }}" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="{{ page.title }} &mdash; {{ site.name }}" />
  <meta name="twitter:description" content="{{ page.description }}" />
  <meta name="twitter:image" content="{{ site.ogImage }}" />
  <meta name="robots" content="index,follow,max-snippet:-1,max-image-preview:large,max-video-preview:-1" />
  <link rel="canonical" href="{{ page.canonical }}" />
  <title>{{ page.title }} &mdash; {{ site.name }}</title>
  <link rel="icon" href="{{ site.favicon }}" type="image/svg+xml" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="{{ site.fontStylesheet }}" rel="stylesheet" />
  {% for href in page.styles %}
  <link rel="stylesheet" href="{{ href }}" />
  {% endfor %}
</head>
