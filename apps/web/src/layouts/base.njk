<!doctype html>
<html lang="en">
{% include "partials/head.njk" %}
<body>
  <a class="skip-link" href="#main">Skip to content</a>
  {% include "partials/hero-bar.njk" %}
  <div class="texture--grain" aria-hidden="true"></div>
  <main id="main" class="page{% if page.pageClass %} {{ page.pageClass }}{% endif %}">
    {% include "partials/site-header.njk" %}
    <section class="page-intro">
      <p class="page-intro__kicker">{{ page.introKicker }}</p>
      <h2 class="page-intro__title">{{ page.introTitle }}</h2>
      <p class="page-intro__text">{{ page.introText }}</p>
    </section>
    {% block content %}{% endblock %}
    {% include "partials/footer.njk" %}
  </main>
  {% block afterMain %}{% endblock %}
  {% for script in page.scripts %}
  <script{% if script.module %} type="module"{% endif %} src="{{ script.src }}"></script>
  {% endfor %}
</body>
</html>
