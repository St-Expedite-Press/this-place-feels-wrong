---
import Base from '../../layouts/Base.astro';
import siteData from '../../data/site.json';

const page = siteData.pages.donateThanks;
const styles = [
  'assets/css/tokens.css',
  'assets/css/interior-base.css',
  'assets/css/layout.css',
  'assets/css/components.css',
  'assets/css/forms.css',
  'assets/css/donate.css',
];
---
<Base
  title={page.title}
  description={page.description}
  canonical={page.canonical}
  subtitle={page.subtitle}
  eyebrow={page.eyebrow}
  introKicker={page.introKicker}
  introTitle={page.introTitle}
  introText={page.introText}
  currentNav={page.currentNav}
  brandMode="utility"
  styles={styles}
>
  <section class="donate-shell">
    <section class="donate-altar donate-altar--compact" aria-labelledby="donate-thanks-anchor">
      <p class="donate-altar__glyph" aria-hidden="true">&#9651; &#10013; &#9651;</p>
      <h2 class="donate-altar__title" id="donate-thanks-anchor">Contribution received.</h2>
      <p class="donate-altar__coords">Work continues through this.</p>
    </section>

    <article class="card donate-orientation donate-orientation--thanks">
      <p>Your support has been handed off to Stripe.</p>
      <p>The press remains small, deliberate, and in motion.</p>
    </article>

    <section class="split-grid">
      <article class="card stack">
        <div>
          <p class="card-kicker">Next step</p>
          <h2 class="section-heading">Return to the site</h2>
          <p class="section-copy section-copy--large">Go back to the portal, read about the press, or continue through the catalog.</p>
        </div>
        <div class="actions">
          <a class="button" href="/">Return to Portal</a>
          <a class="button-secondary" href="/about">About the Press</a>
          <a class="button-secondary" href="/books">Books</a>
        </div>
      </article>

      <aside class="card stack">
        <div>
          <p class="card-kicker">Receipt</p>
          <h2 class="section-heading">Payment details</h2>
        </div>
        <p class="section-copy">Stripe handles payment processing and receipts. For anything else, use <a href="/about">About</a>.</p>
      </aside>
    </section>
  </section>

  <Fragment slot="scripts">
    <script is:inline src="/assets/js/site-shell.js" type="module"></script>
  </Fragment>
</Base>
