---
import Base from '../layouts/Base.astro';
import siteData from '../data/site.json';

const page = siteData.pages.gallery;
const styles = [
  'assets/css/tokens.css',
  'assets/css/interior-base.css',
  'assets/css/layout.css',
  'assets/css/components.css',
  'assets/css/gallery.css',
];
---
<Base
  title={page.title}
  description={page.description}
  canonical={page.canonical}
  subtitle={page.subtitle}
  eyebrow={page.eyebrow}
  introKicker={page.introKicker}
  introTitle={page.introTitle}
  introText={page.introText}
  currentNav={page.currentNav}
  styles={styles}
>
  <div class="store-toolbar" id="store-toolbar" aria-label="Store collections"></div>

  <section class="store-grid" id="store-grid" aria-label="Store products"></section>

  <footer class="store-footer">
    <p class="helper-text" id="store-status" role="status" aria-live="polite">Loading...</p>
    <p class="section-copy">Checkout at <strong>shop.stexpedite.press</strong>. For support, <a href="/about">contact the press</a>.</p>
  </footer>

  <Fragment slot="scripts">
    <script is:inline src="/assets/js/site-shell.js" type="module"></script>
    <script is:inline src="/assets/js/gallery-page.js" type="module"></script>
  </Fragment>
</Base>
