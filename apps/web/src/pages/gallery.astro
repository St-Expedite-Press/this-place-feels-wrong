---
import Base from '../layouts/Base.astro';
import siteData from '../data/site.json';

const page = siteData.pages.gallery;
const styles = [
  'assets/css/tokens.css',
  'assets/css/interior-base.css',
  'assets/css/layout.css',
  'assets/css/components.css',
  'assets/css/gallery.css',
];
---
<Base
  title={page.title}
  description={page.description}
  canonical={page.canonical}
  subtitle={page.subtitle}
  eyebrow={page.eyebrow}
  introKicker={page.introKicker}
  introTitle={page.introTitle}
  introText={page.introText}
  currentNav={page.currentNav}
  brandMode="editorial"
  styles={styles}
>
  <section class="section-block" aria-labelledby="store-inventory-title">
    <div class="section-header">
      <p class="card-kicker">Current inventory</p>
      <h2 class="section-heading section-heading--display" id="store-inventory-title">Objects from the press's working life.</h2>
    </div>
    <div class="store-toolbar" id="store-toolbar" aria-label="Store collections"></div>
    <section class="store-grid" id="store-grid" aria-label="Store products"></section>
    <footer class="store-footer quiet-panel">
      <p class="helper-text" id="store-status" role="status" aria-live="polite">Loading storefront...</p>
      <div id="store-fallback-copy">
        <p class="section-copy">Books when they exist. Prints when they mean something. Objects from the press's working life.</p>
      </div>
      <p class="section-copy">Checkout at <strong>shop.stexpedite.press</strong>.</p>
    </footer>
  </section>

  <Fragment slot="scripts">
    <script is:inline src="/assets/js/site-shell.js" type="module"></script>
    <script is:inline src="/assets/js/gallery-page.js" type="module"></script>
  </Fragment>
</Base>
