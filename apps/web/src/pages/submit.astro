---
import Base from '../layouts/Base.astro';
import siteData from '../data/site.json';

const page = siteData.pages.submit;
const styles = [
  'assets/css/tokens.css',
  'assets/css/interior-base.css',
  'assets/css/layout.css',
  'assets/css/components.css',
  'assets/css/forms.css',
];
---
<Base
  title={page.title}
  description={page.description}
  canonical={page.canonical}
  subtitle={page.subtitle}
  eyebrow={page.eyebrow}
  introKicker={page.introKicker}
  introTitle={page.introTitle}
  introText={page.introText}
  currentNav={page.currentNav}
  styles={styles}
>
  <section class="form-trust form-trust--two">
    <div class="trust-card trust-card--center">
      <strong>Use Submit for</strong>
      Manuscripts, project inquiries, and query letters.
    </div>
    <div class="trust-card trust-card--center">
      <strong>After you send</strong>
      You get a reference email. Attach files by replying to that thread.
    </div>
  </section>

  <section class="split-card-grid split-card-grid--balanced">
    <article class="form-card form-shell form-card--tall">
      <div>
        <p class="card-kicker">Primary channel</p>
        <h2 class="section-heading">Submission inquiry</h2>
        <p class="section-copy section-copy--large">Keep it concise. Project type, length, stage, and ask.</p>
      </div>
      <form class="form-grid" id="submit-form">
        <input id="submit-website" name="website" type="text" tabindex="-1" autocomplete="off" aria-hidden="true" hidden />
        <div class="field">
          <label for="submit-email">Email</label>
          <input class="input" id="submit-email" name="email" type="email" autocomplete="email" placeholder="your@email.com" required />
        </div>
        <div class="field">
          <label for="submit-note">Project note</label>
          <textarea class="textarea" id="submit-note" name="note" placeholder="Project type, length, stage, and what you are asking for."></textarea>
        </div>
        <div class="actions">
          <button class="button" id="submit-button" type="submit">Send inquiry</button>
        </div>
      </form>
      <div class="status-panel" id="submit-helper" role="status" aria-live="polite" hidden>
        <div data-status-text></div>
        <div class="status-panel__actions">
          <a class="status-action" id="submit-mailto-fallback" href="mailto:editor@stexpedite.press">Open email</a>
          <button class="status-action" id="submit-copy" type="button">Copy fallback</button>
        </div>
      </div>
    </article>

    <aside class="form-card stack form-card--tall form-card--split">
      <div>
        <p class="card-kicker">Not a submission</p>
        <h2 class="section-heading">Use About instead</h2>
      </div>
      <ul class="meta-list">
        <li>Rights, press, and collaborations.</li>
        <li>Operational help with the site or store.</li>
        <li>Anything that is not a manuscript or editorial project.</li>
      </ul>
      <div class="actions">
        <a class="pill-link" href="/about">Go to About</a>
      </div>
    </aside>
  </section>

  <Fragment slot="scripts">
    <script is:inline src="/assets/js/site-shell.js" type="module"></script>
    <script is:inline src="/assets/js/submit-page.js" type="module"></script>
  </Fragment>
</Base>
