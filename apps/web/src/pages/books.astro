---
import Base from '../layouts/Base.astro';
import siteData from '../data/site.json';

const page = siteData.pages.books;
const styles = [
  'assets/css/tokens.css',
  'assets/css/interior-base.css',
  'assets/css/layout.css',
  'assets/css/components.css',
  'assets/css/books.css',
];

const series = [
  {
    key: 'sexp',
    num: '01',
    name: 'SEXP',
    match: ['sexp'],
    accent: 'signal',
    ethos: 'Original fiction, poetry, novella, and hybrid work. Formal pressure over market fit. Very few entries.',
  },
  {
    key: 'library',
    num: '02',
    name: 'Library of the Southern Civilization',
    match: ['library', 'southern', 'lsc'],
    accent: 'relief',
    ethos: 'Recovery editions of Southern texts that deserve continued circulation, returned in editions that treat them as live, not archival.',
  },
  {
    key: 'translation',
    num: '03',
    name: 'Translation',
    match: ['translation', 'translated'],
    accent: 'signal',
    ethos: 'Formal and spiritual registers from traditions Anglo-American publishing has spent decades flattening. Brought across without domestication.',
  },
];
---
<Base
  title={page.title}
  description={page.description}
  canonical={page.canonical}
  subtitle={page.subtitle}
  eyebrow={page.eyebrow}
  introKicker={page.introKicker}
  introTitle={page.introTitle}
  introText={page.introText}
  currentNav={page.currentNav}
  brandMode="editorial"
  styles={styles}
>
  <section class="books-carousel" aria-roledescription="carousel" aria-labelledby="series-title">
    <div class="section-header">
      <p class="card-kicker">The three lines</p>
      <h2 class="section-heading section-heading--display" id="series-title">Three arms, one standard.</h2>
    </div>

    <div class="carousel-viewport" id="series-viewport">
      <div class="carousel-track" id="series-track">
        {series.map((s, i) => (
          <article
            class="series-card"
            data-accent={s.accent}
            data-series-match={s.match.join(',')}
            role="group"
            aria-roledescription="slide"
            aria-label={`${i + 1} of ${series.length}: ${s.name}`}
          >
            <p class="series-card__num">{s.num} / {series.length.toString().padStart(2, '0')}</p>
            <h3 class="series-card__name">{s.name}</h3>
            <p class="series-card__ethos">{s.ethos}</p>
            <div class="series-card__titles" data-series-titles>
              <p class="helper-text" data-series-status>Loading titles&hellip;</p>
            </div>
          </article>
        ))}
      </div>
    </div>

    <div class="carousel-controls">
      <button class="carousel-btn" type="button" data-carousel-prev aria-label="Previous series">&lsaquo;</button>
      <div class="carousel-dots" id="series-dots" role="tablist" aria-label="Choose a series"></div>
      <button class="carousel-btn" type="button" data-carousel-next aria-label="Next series">&rsaquo;</button>
    </div>
  </section>

  <section class="section-block" aria-labelledby="books-cta-title">
    <div class="section-header">
      <p class="card-kicker">Bring work to the press</p>
      <h2 class="section-heading" id="books-cta-title">Books in public circulation and active work.</h2>
    </div>
    <div class="section-actions">
      <a class="button" href="/connect?about=manuscript">Submission inquiries</a>
      <a class="button-secondary" href="/connect?about=rights">Rights or press inquiries</a>
    </div>
  </section>

  <Fragment slot="scripts">
    <script is:inline src="/assets/js/site-shell.js" type="module"></script>
    <script is:inline src="/assets/js/books-page.js" type="module"></script>
  </Fragment>
</Base>
