{% extends "layouts/base.njk" %}

{% block content %}
<section class="form-trust">
  <div class="trust-card"><strong>Use this page for</strong>General questions, rights inquiries, collaborations, press, and editorial correspondence.</div>
  <div class="trust-card"><strong>Response pattern</strong>Messages arrive through the site and are acknowledged by email when delivery succeeds.</div>
  <div class="trust-card"><strong>Not for manuscripts</strong>If you are pitching a manuscript or project, use the submission inquiry page instead.</div>
</section>

<section class="split-card-grid">
  <article class="form-card form-shell">
    <div>
      <h2 class="section-heading">General contact</h2>
      <p class="section-copy">Tell us what you need and include enough context to route the message quickly.</p>
    </div>
    <form class="form-grid" id="contact-form">
      <input id="contact-website" name="website" type="text" tabindex="-1" autocomplete="off" aria-hidden="true" hidden />
      <div class="field">
        <label for="contact-reason">Reason</label>
        <select class="select" id="contact-reason" name="reason">
          <option value="General">General</option>
          <option value="Rights">Rights</option>
          <option value="Press">Press</option>
          <option value="Collaboration">Collaboration</option>
        </select>
      </div>
      <div class="field">
        <label for="contact-email">Email</label>
        <input class="input" id="contact-email" name="email" type="email" autocomplete="email" placeholder="your@email.com" required />
      </div>
      <div class="field">
        <label for="contact-message">Message</label>
        <textarea class="textarea" id="contact-message" name="message" placeholder="What should we know before replying?" required></textarea>
      </div>
      <div class="actions">
        <button class="button" id="contact-submit" type="submit">Send message</button>
      </div>
    </form>
    <div class="status-panel" id="contact-helper" role="status" aria-live="polite" hidden>
      <div data-status-text></div>
      <div class="status-panel__actions">
        <a class="status-action" id="contact-mailto-fallback" href="mailto:editor@stexpedite.press">Open email</a>
        <button class="status-action" id="contact-copy" type="button">Copy fallback</button>
      </div>
    </div>
  </article>

  <aside class="form-card stack">
    <div>
      <h2 class="section-heading">Updates signup</h2>
      <p class="section-copy">Save your address to the first-party list, then continue to the hosted feed if you want that channel as well.</p>
    </div>
    <div class="field">
      <label for="contact-updates-email">Email for updates</label>
      <input class="input" id="contact-updates-email" type="email" autocomplete="email" placeholder="you@example.com" />
    </div>
    <div class="actions">
      <button class="button-secondary" id="contact-updates-submit" type="button">Save email</button>
    </div>
    <div class="status-panel" id="contact-updates-helper" role="status" aria-live="polite" hidden>
      <div data-status-text></div>
      <div class="status-panel__actions">
        <a class="status-action" id="contact-updates-open" href="https://ecoamericana.substack.com/s/ephemera" target="_blank" rel="noopener noreferrer">Continue to Substack</a>
        <button class="status-action" id="contact-updates-copy" type="button">Copy link</button>
        <button class="status-action" id="contact-updates-dismiss" type="button">Dismiss</button>
      </div>
    </div>
    <p class="aside-note">For manuscript and project approaches, use <a href="submit.html">Submission</a> instead of general contact.</p>
  </aside>
</section>
{% endblock %}
