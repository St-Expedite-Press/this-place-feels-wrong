---
import Base from '../layouts/Base.astro';
import siteData from '../data/site.json';

const page = siteData.pages.donate;
const styles = [
  'assets/css/tokens.css',
  'assets/css/interior-base.css',
  'assets/css/layout.css',
  'assets/css/components.css',
  'assets/css/forms.css',
  'assets/css/donate.css',
];
---
<Base
  title={page.title}
  description={page.description}
  canonical={page.canonical}
  subtitle={page.subtitle}
  eyebrow={page.eyebrow}
  introKicker={page.introKicker}
  introTitle={page.introTitle}
  introText={page.introText}
  currentNav={page.currentNav}
  styles={styles}
>
  <section class="donate-altar" aria-labelledby="donate-altar-title">
    <p class="donate-altar__glyph" aria-hidden="true">&#9651; &#10013; &#9651;</p>
    <h2 class="donate-altar__title" id="donate-altar-title">St. Expedite Press</h2>
    <p class="donate-altar__coords">29.9511&deg; N / 90.0715&deg; W</p>
  </section>

  <section class="card donate-orientation" aria-label="Donation orientation">
    <p>This press operates on direct support.</p>
    <p>Each contribution sustains:</p>
    <ul>
      <li>Publication</li>
      <li>Archive</li>
      <li>Ongoing work</li>
    </ul>
  </section>

  <section class="donate-grid" aria-label="Donation form">
    <article class="form-card donate-seal form-shell">
      <div>
        <p class="card-kicker">Offering surface</p>
        <h2 class="section-heading">Choose the signal</h2>
        <p class="section-copy section-copy--large">Select an amount or enter one directly. Checkout opens through Stripe.</p>
      </div>

      <div class="donate-amount-grid" role="group" aria-label="Suggested donation amounts">
        <button class="donate-amount-button" type="button" data-donation-amount="10">
          <strong>$10</strong>
          <span>Signal</span>
        </button>
        <button class="donate-amount-button" type="button" data-donation-amount="25">
          <strong>$25</strong>
          <span>Archive</span>
        </button>
        <button class="donate-amount-button" type="button" data-donation-amount="50">
          <strong>$50</strong>
          <span>Publication</span>
        </button>
        <button class="donate-amount-button" type="button" data-donation-amount="100">
          <strong>$100</strong>
          <span>Continuity</span>
        </button>
      </div>

      <form class="form-grid" id="donate-form">
        <div class="field donate-field">
          <label for="donate-amount">Custom amount (USD)</label>
          <input class="input" id="donate-amount" name="amount" type="number" min="5" max="1000" step="1" inputmode="decimal" autocomplete="off" placeholder="25" required />
          <p class="donate-field-note">Minimum $5. Maximum $1,000.</p>
        </div>
        <p class="donate-selected" id="donate-selected-amount">Choose an amount to seal.</p>
        <div class="donate-commitment">
          <button class="button donate-cta" id="donate-submit" type="submit">Seal contribution</button>
          <p class="donate-checkout-note">Secure checkout opens through Stripe.</p>
          <p class="donate-continuity">Work continues through this.</p>
        </div>
        <div class="donate-actions">
          <a class="button-secondary" href="/about">About the press</a>
        </div>
      </form>

      <div class="status-panel" id="donate-helper" role="status" aria-live="polite" hidden>
        <div data-status-text></div>
      </div>
    </article>

    <aside class="form-card donate-summary">
      <div class="stack">
        <div>
          <p class="card-kicker">Continuity</p>
          <h2 class="section-heading">What this sustains</h2>
        </div>
        <ul class="donate-support-list">
          <li>Publication</li>
          <li>Archive</li>
          <li>Ongoing work</li>
        </ul>
      </div>

      <p class="donate-fine-print">The press remains small by design. Support keeps that scale possible.</p>
    </aside>
  </section>

  <Fragment slot="scripts">
    <script is:inline src="/assets/js/site-shell.js" type="module"></script>
    <script is:inline src="/assets/js/donate-page.js" type="module"></script>
  </Fragment>
</Base>
