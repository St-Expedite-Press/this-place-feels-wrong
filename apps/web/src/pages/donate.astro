---
import Base from '../layouts/Base.astro';
import siteData from '../data/site.json';

const page = siteData.pages.donate;
const styles = [
  'assets/css/tokens.css',
  'assets/css/interior-base.css',
  'assets/css/layout.css',
  'assets/css/components.css',
  'assets/css/forms.css',
  'assets/css/donate-portal.css',
];
---
<Base
  title={page.title}
  description={page.description}
  canonical={page.canonical}
  subtitle={page.subtitle}
  eyebrow={page.eyebrow}
  introKicker={page.introKicker}
  introTitle={page.introTitle}
  introText={page.introText}
  currentNav={page.currentNav}
  brandMode="utility"
  styles={styles}
>
  <section class="section-block section-block--reading donate-stage" aria-labelledby="donate-form-title">
    <article class="card editorial-card stack donate-orientation">
      <p class="card-kicker">What it sustains</p>
      <h2 class="section-heading section-heading--display">Where your money goes.</h2>
      <p class="section-copy section-copy--large">The catalog, archive editions, translation program, RICE Magazine, and the fellowship can remain direct because support does not pass through a grant committee or institution.</p>
    </article>

    <article class="form-card form-shell">
      <div>
        <p class="card-kicker">One-time contribution</p>
        <h2 class="section-heading" id="donate-form-title">Choose an amount or enter your own.</h2>
      </div>

      <form class="form-grid donate-form" id="donate-form">
        <div class="donate-presets" role="group" aria-label="Suggested donation amounts">
          <button class="donate-preset" type="button" data-donation-amount="10" aria-label="Donate 10 dollars">$10</button>
          <button class="donate-preset" type="button" data-donation-amount="25" aria-label="Donate 25 dollars">$25</button>
          <button class="donate-preset" type="button" data-donation-amount="50" aria-label="Donate 50 dollars">$50</button>
          <button class="donate-preset" type="button" data-donation-amount="100" aria-label="Donate 100 dollars">$100</button>
        </div>

        <p class="donate-feedback" id="donate-selected-amount" aria-live="polite"></p>

        <div class="field">
          <label for="donate-amount">Amount in US dollars</label>
          <input class="input donate-input" id="donate-amount" name="amount" type="number" min="5" max="1000" step="1" inputmode="decimal" autocomplete="off" placeholder="Amount (USD)" required />
        </div>

        <div class="cf-turnstile" data-sitekey="0x4AAAAAADc-GOYeYwVaZA_I" data-theme="dark" data-appearance="interaction-only"></div>

        <div class="actions">
          <button class="button donate-submit" id="donate-submit" type="submit">Continue to Stripe</button>
        </div>
        <p class="form-assurance">Stripe handles checkout and receipts. Minimum contribution is $5.</p>

        <div class="status-panel donate-status" id="donate-helper" role="status" aria-live="polite" hidden>
          <div data-status-text></div>
        </div>
      </form>
    </article>
  </section>

  <Fragment slot="scripts">
    <script is:inline src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
    <script is:inline src="/assets/js/site-shell.js" type="module"></script>
    <script is:inline src="/assets/js/donate-page.js" type="module"></script>
  </Fragment>
</Base>
