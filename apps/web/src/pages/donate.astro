---
import { ViewTransitions } from 'astro:transitions';
import siteData from '../data/site.json';

const { site, pages } = siteData;
const page = pages.donate;
---
<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta name="description" content={page.description} />
<meta name="theme-color" content={site.themeColor} />
<meta name="color-scheme" content="dark" />
<meta property="og:site_name" content={site.name} />
<meta property="og:type" content="website" />
<meta property="og:title" content={`${page.title} \u2014 ${site.name}`} />
<meta property="og:description" content={page.description} />
<meta name="robots" content="index,follow,max-snippet:-1,max-image-preview:large,max-video-preview:-1" />
<meta property="og:url" content={page.canonical} />
<meta property="og:image" content={site.ogImage} />
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={`${page.title} \u2014 ${site.name}`} />
<meta name="twitter:description" content={page.description} />
<meta name="twitter:image" content={site.ogImage} />
<link rel="canonical" href={page.canonical} />
<title>{page.title} &mdash; {site.name}</title>

<link rel="icon" href={`/${site.favicon}`} type="image/svg+xml" />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href={site.fontStylesheet} rel="stylesheet" />

<link rel="stylesheet" href="/assets/css/base.css" />
<link rel="stylesheet" href="/assets/css/effects.css" />
<link rel="stylesheet" href="/assets/css/a11y.css" />
<link rel="stylesheet" href="/assets/css/donate.css" />
<ViewTransitions />
</head>

<body class="donate-portal-page">
<a class="skip-link" href="#main">Skip to content</a>

<div class="texture--grain"></div>
<div class="cursor-glow"></div>

<main id="main" class="donate-portal" tabindex="-1">
  <section class="donate-stage" aria-label="Donation portal">
    <h1 class="donate-sr-only">Donate to St. Expedite Press</h1>

    <div class="donate-portal-frame" aria-hidden="true">
      <div class="donate-portal-noise"></div>
      <picture class="donate-portal-media">
        <source srcset="/assets/gif/crow_glitch_text.gif" type="image/gif" media="(prefers-reduced-motion: no-preference)">
        <img src="/assets/img/crow_glitch_text_still.png" alt="">
      </picture>
      <div class="donate-portal-seal">
        <span>&#9651;</span>
        <span>&#10013;</span>
        <span>&#9651;</span>
      </div>
    </div>

    <form class="donate-offering" id="donate-form">
      <div class="donate-amount-ring" role="group" aria-label="Suggested donation amounts">
        <button class="donate-amount-button donate-amount-button--nw" type="button" data-donation-amount="10" aria-label="Donate 10 dollars">$10</button>
        <button class="donate-amount-button donate-amount-button--ne" type="button" data-donation-amount="25" aria-label="Donate 25 dollars">$25</button>
        <button class="donate-amount-button donate-amount-button--sw" type="button" data-donation-amount="50" aria-label="Donate 50 dollars">$50</button>
        <button class="donate-amount-button donate-amount-button--se" type="button" data-donation-amount="100" aria-label="Donate 100 dollars">$100</button>
      </div>

      <div class="donate-console">
        <p class="donate-console__intro">Direct support sustains the work.</p>
        <label class="donate-sr-only" for="donate-amount">Donation amount in US dollars</label>
        <input class="donate-input" id="donate-amount" name="amount" type="number" min="5" max="1000" step="1" inputmode="decimal" autocomplete="off" placeholder="Custom amount" required />
        <p class="donate-selected" id="donate-selected-amount">Choose an amount.</p>
        <button class="donate-submit" id="donate-submit" type="submit">Donate</button>
        <p class="donate-checkout-note">Secure checkout via Stripe.</p>
        <div class="donate-status" id="donate-helper" role="status" aria-live="polite" hidden>
          <div data-status-text></div>
        </div>
      </div>
    </form>
  </section>

  <footer class="donate-footer">
    <p class="donate-footer__line">
      <a href="/">Portal</a>
      <span>//</span>
      <a href="/about">About</a>
      <span>//</span>
      <a href="/books">Books</a>
      <span>//</span>
      <a href="/submit">Submit</a>
      <span>//</span>
      <span>29.9511&deg; N &mdash; 90.0715&deg; W</span>
      <span>//</span>
      <span aria-hidden="true">&#9651; &#10013; &#9651;</span>
    </p>
  </footer>
</main>

<script is:inline src="/assets/js/site-shell.js" type="module"></script>
<script is:inline src="/assets/js/index-effects.js"></script>
<script is:inline src="/assets/js/donate-page.js" type="module"></script>
</body>
</html>
