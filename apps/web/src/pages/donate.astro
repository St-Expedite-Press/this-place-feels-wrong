---
import { ViewTransitions } from 'astro:transitions';
import siteData from '../data/site.json';

const { site, pages } = siteData;
const page = pages.donate;
---
<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta name="description" content={page.description} />
<meta name="theme-color" content={site.themeColor} />
<meta name="color-scheme" content="dark" />
<meta property="og:site_name" content={site.name} />
<meta property="og:type" content="website" />
<meta property="og:title" content={`${page.title} \u2014 ${site.name}`} />
<meta property="og:description" content={page.description} />
<meta name="robots" content="index,follow,max-snippet:-1,max-image-preview:large,max-video-preview:-1" />
<meta property="og:url" content={page.canonical} />
<meta property="og:image" content={site.ogImage} />
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={`${page.title} \u2014 ${site.name}`} />
<meta name="twitter:description" content={page.description} />
<meta name="twitter:image" content={site.ogImage} />
<link rel="canonical" href={page.canonical} />
<title>{page.title} &mdash; {site.name}</title>

<link rel="icon" href={`/${site.favicon}`} type="image/svg+xml" />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href={site.fontStylesheet} rel="stylesheet" />

<link rel="stylesheet" href="/assets/css/base.css" />
<link rel="stylesheet" href="/assets/css/effects.css" />
<link rel="stylesheet" href="/assets/css/a11y.css" />
<link rel="stylesheet" href="/assets/css/donate.css" />
<ViewTransitions />
</head>

<body class="donate-portal-page">
<a class="skip-link" href="#main">Skip to content</a>

<div class="texture--grain"></div>
<div class="cursor-glow"></div>

<main id="main" class="donate-portal" tabindex="-1">
  <div class="donate-flash"></div>

  <header class="donate-portal__header" aria-labelledby="donate-title">
    <a class="donate-portal__home" href="/">ST.EXP</a>
    <h1 class="donate-portal__title" id="donate-title">
      <span>Southern Letters will rise again.</span>
      <span>This is how it happens.</span>
    </h1>
    <div class="donate-portal__hinge" aria-hidden="true">&#9651; &#10013; &#9651;</div>
  </header>

  <section class="donate-stage" aria-label="Donation portal">
    <div class="donate-portal-frame" aria-hidden="true">
      <div class="donate-portal-noise"></div>
      <picture class="donate-portal-media">
        <source srcset="/assets/gif/crow_glitch_text.gif" type="image/gif" media="(prefers-reduced-motion: no-preference)">
        <img src="/assets/img/crow_glitch_text_still.png" alt="">
      </picture>
      <div class="donate-portal-seal">
        <span>&#9651;</span>
        <span>&#10013;</span>
        <span>&#9651;</span>
      </div>
    </div>

    <div class="donate-orbit donate-orbit--top">
      <p>Direct support sustains the work.</p>
      <p>Publication / Archive / Ongoing</p>
    </div>

    <form class="donate-offering" id="donate-form">
      <div class="donate-amount-ring" role="group" aria-label="Suggested donation amounts">
        <button class="donate-amount-button donate-amount-button--nw" type="button" data-donation-amount="10">
          <strong>$10</strong>
          <span>Signal</span>
        </button>
        <button class="donate-amount-button donate-amount-button--ne" type="button" data-donation-amount="25">
          <strong>$25</strong>
          <span>Archive</span>
        </button>
        <button class="donate-amount-button donate-amount-button--sw" type="button" data-donation-amount="50">
          <strong>$50</strong>
          <span>Publication</span>
        </button>
        <button class="donate-amount-button donate-amount-button--se" type="button" data-donation-amount="100">
          <strong>$100</strong>
          <span>Continuity</span>
        </button>
      </div>

      <div class="donate-console">
        <label for="donate-amount">Enter an amount.</label>
        <input class="donate-input" id="donate-amount" name="amount" type="number" min="5" max="1000" step="1" inputmode="decimal" autocomplete="off" placeholder="25" required />
        <p class="donate-selected" id="donate-selected-amount">Choose an amount. Seal it.</p>
        <button class="donate-submit" id="donate-submit" type="submit">Seal the contribution</button>
        <p class="donate-checkout-note">Secure checkout via Stripe. Work continues through this.</p>
        <div class="donate-status" id="donate-helper" role="status" aria-live="polite" hidden>
          <div data-status-text></div>
        </div>
      </div>
    </form>
  </section>

  <footer class="donate-footer">
    <nav class="donate-footer__nav" aria-label="Footer">
      <a href="/">Portal</a>
      <a href="/about">About</a>
      <a href="/books">Books</a>
      <a href="/submit">Submit</a>
    </nav>
    <p class="donate-footer__coords">29.9511&deg; N &mdash; 90.0715&deg; W</p>
    <div class="donate-footer__divider" aria-hidden="true">&#9651; &#10013; &#9651;</div>
  </footer>
</main>

<script is:inline src="/assets/js/site-shell.js" type="module"></script>
<script is:inline src="/assets/js/index-effects.js"></script>
<script is:inline src="/assets/js/donate-page.js" type="module"></script>
</body>
</html>
