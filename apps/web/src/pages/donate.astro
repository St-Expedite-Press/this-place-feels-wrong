---
import BasePortal from '../layouts/BasePortal.astro';
import siteData from '../data/site.json';

const { site, pages } = siteData;
const page = pages.donate;
---
<BasePortal
  title={page.title}
  description={page.description}
  canonical={page.canonical}
  brandMode="utility"
  bodyClass="donate-portal-page"
  styles={['assets/css/donate-portal.css']}
>
  <main id="main" class="donate-page-shell" tabindex="-1">
    <h1 class="header-title">DONATE</h1>

    <section class="donate-stage" aria-label="Donation portal">
      <p class="donate-statement">The money goes to the work.</p>
      <p class="donate-context">The catalog, the archive editions, the translation program, RICE Magazine, and the fellowship — direct support makes each of these possible without a grant committee or an institution's approval.</p>

      <form class="donate-surface" id="donate-form">
        <div class="donate-presets" role="group" aria-label="Suggested donation amounts">
          <button class="donate-preset" type="button" data-donation-amount="10" aria-label="Donate 10 dollars">$10</button>
          <button class="donate-preset" type="button" data-donation-amount="25" aria-label="Donate 25 dollars">$25</button>
          <button class="donate-preset" type="button" data-donation-amount="50" aria-label="Donate 50 dollars">$50</button>
          <button class="donate-preset" type="button" data-donation-amount="100" aria-label="Donate 100 dollars">$100</button>
        </div>

        <div class="cf-turnstile" data-sitekey="0x4AAAAAADc-GOYeYwVaZA_I" data-theme="dark"></div>

        <p class="donate-feedback" id="donate-selected-amount" aria-live="polite"></p>

        <div class="donate-console">
          <label class="donate-sr-only" for="donate-amount">Donation amount in US dollars</label>
          <input class="donate-input" id="donate-amount" name="amount" type="number" min="5" max="1000" step="1" inputmode="decimal" autocomplete="off" placeholder="Amount (USD)" required />
          <button class="donate-submit" id="donate-submit" type="submit">Donate</button>
        </div>
        <p class="donate-assurance">Stripe handles checkout and receipts. Minimum contribution is $5.</p>

        <div class="donate-status" id="donate-helper" role="status" aria-live="polite" hidden>
          <div data-status-text></div>
        </div>
      </form>
    </section>

    <div class="splash">
      <p class="splash__eyebrow">29.9511&deg; N &mdash; 90.0715&deg; W</p>
      <p class="lede">...in the key of Night.</p>
      <div class="divider">&#9651; &#10013; &#9651;</div>
      <div class="splash__foot">
        <a href="/">Portal</a>
        {site.footerLinks.filter(item => item.href !== '/donate').map(item => (
          <> // <a href={item.href}>{item.label}</a></>
        ))}
      </div>
    </div>
  </main>

  <Fragment slot="scripts">
    <script is:inline src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
    <script is:inline src="/assets/js/site-shell.js" type="module"></script>
    <script is:inline src="/assets/js/donate-page.js" type="module"></script>
  </Fragment>
</BasePortal>
