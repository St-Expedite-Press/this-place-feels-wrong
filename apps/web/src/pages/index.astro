---
import { ViewTransitions } from 'astro:transitions';
import HeroBar from '../components/HeroBar.astro';
import siteData from '../data/site.json';

const { site, pages } = siteData;
const page = pages.index;
const homeMetaTitle = 'St. Expedite Press — Southern Fiction, Translation & Archive | New Orleans';
const homeMetaDescription = 'St. Expedite Press publishes original Southern fiction, archival reprints, & translation from New Orleans. A non-institutional press for Southern writing at its formal & spiritual extremity.';
const homeOgTitle = 'St. Expedite Press';
const homeOgDescription = 'A New Orleans press for Southern writing at its formal & spiritual extremity. Fiction, archive, translation.';
---
<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta name="description" content={homeMetaDescription} />
<meta name="theme-color" content={site.themeColor} />
<meta name="color-scheme" content="dark" />
<meta property="og:site_name" content={site.name} />
<meta property="og:type" content="website" />
<meta property="og:title" content={homeOgTitle} />
<meta property="og:description" content={homeOgDescription} />
<meta name="robots" content="index,follow,max-snippet:-1,max-image-preview:large,max-video-preview:-1" />
<meta property="og:url" content={page.canonical} />
<meta property="og:image" content={site.ogImage} />
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={homeOgTitle} />
<meta name="twitter:description" content={homeOgDescription} />
<meta name="twitter:image" content={site.ogImage} />
<link rel="canonical" href={page.canonical} />
<title>{homeMetaTitle}</title>

<link rel="icon" href={`/${site.favicon}`} type="image/svg+xml" />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href={site.fontStylesheet} rel="stylesheet" />
<link rel="preload" as="image" href="/assets/img/crow_glitch_text_still.webp" type="image/webp" fetchpriority="high" />

<link rel="stylesheet" href="/assets/css/tokens.css" />
<link rel="stylesheet" href="/assets/css/interior-base.css" />
<link rel="stylesheet" href="/assets/css/effects.css" />
<link rel="stylesheet" href="/assets/css/a11y.css" />
<link rel="stylesheet" href="/assets/css/hero-bar.css" />
<link rel="stylesheet" href="/assets/css/footer.css" />
<link rel="stylesheet" href="/assets/css/portal.css" />
<ViewTransitions />
</head>

<body data-brand-mode="ritual">

<a class="skip-link" href="#main">Skip to content</a>

<div class="texture--grain"></div>
<div class="cursor-glow"></div>

<HeroBar />

<main id="main" class="page" tabindex="-1">
<h1 class="home-heading-sr">St. Expedite Press</h1>

<div class="portal-mobile">
  <div class="wrap">
    <div class="mobile-fit">
      <header>
        <p class="title" aria-hidden="true">St. Expedite Press</p>
      </header>

      <section class="portal-stack">
        <a class="portal-link" href="/books">Books</a>

        <div class="portal" aria-hidden="true">
          <picture class="portal-media" data-animated-src="/assets/img/crow_glitch_text.webp">
            <source srcset="/assets/img/crow_glitch_text_still.webp" type="image/webp">
            <img src="/assets/img/crow_glitch_text_still.png" alt="" width="768" height="768" fetchpriority="high" decoding="async">
          </picture>
        </div>

        <a class="portal-link" href="/about">About</a>

        <div class="thin-band" aria-label="Letters from the press">
          <p class="thin-copy">Letters from the press. New titles, critical dispatches, & notes on the tradition.</p>
          <form class="thin-form" id="index-updates-form">
            <input class="thin-input" id="index-updates-email" name="email" type="email" autocomplete="email" placeholder="your@email.com" aria-label="Email for letters from the press" required>
            <button class="thin-button" type="submit">Subscribe</button>
          </form>
          <div class="thin-helper" id="index-updates-helper" aria-live="polite" hidden>
            <div id="index-updates-helper-text"></div>
            <div class="thin-helper__actions">
              <a class="thin-helper__link" id="index-updates-open" href="https://ecoamericana.substack.com/s/ephemera">Continue to Substack</a>
              <button class="thin-helper__btn" id="index-updates-copy" type="button">Copy</button>
              <button class="thin-helper__btn" id="index-updates-dismiss" type="button">Dismiss</button>
            </div>
          </div>
        </div>
      </section>

      <footer class="foot">
        <p class="splash__eyebrow">29.9511&deg; N &mdash; 90.0715&deg; W</p>
        <p class="lede">...in the key of Night.</p>
        <div class="divider">&#9651; &#10013; &#9651;</div>
      </footer>
    </div>
  </div>
</div>

<div class="portal-desktop">
  <div class="portal-flash"></div>

  <p class="header-title" aria-hidden="true">ST. EXPEDITE PRESS</p>

  <div class="portal-frame">
    <div class="portal-noise"></div>
    <picture class="portal-media" data-animated-src="/assets/img/crow_glitch_text.webp">
      <source srcset="/assets/img/crow_glitch_text_still.webp" type="image/webp">
      <img src="/assets/img/crow_glitch_text_still.png" alt="" width="768" height="768" fetchpriority="high" decoding="async">
    </picture>
  </div>

  <nav class="mobile-index-nav">
    <a href="/books">Books</a>
    <a href="/gallery">Store</a>
    <a href="/about">About</a>
    <a href="/lab">Lab</a>
  </nav>

  <nav class="big-nav" aria-label="Primary">
    <a href="/books"   class="big-word big-word--books"  >BOOKS</a>
    <div></div>
    <a href="/gallery" class="big-word big-word--store"  >STORE</a>
    <div></div><div></div><div></div>
    <a href="/about"   class="big-word big-word--about"  >ABOUT</a>
    <div></div>
    <a href="/lab"     class="big-word big-word--lab"    >LAB</a>
  </nav>

  <div class="splash">
    <p class="splash__eyebrow">29.9511&deg; N &mdash; 90.0715&deg; W</p>
    <p class="lede">...in the key of Night.</p>
    <div class="divider">&#9651; &#10013; &#9651;</div>
    <div class="splash__foot">
      <a href="/books">Books</a> // <a href="/submit">Submit</a> // <a href="/about">About</a> // <a href="/donate">Donate</a>
    </div>
  </div>
</div>

</main>

<script is:inline src="/assets/js/site-shell.js" type="module"></script>
<script is:inline src="/assets/js/index-effects.js"></script>

<script is:inline>
const applyMobileFit = () => {
  const mobileFit = document.querySelector('.portal-mobile .mobile-fit');
  const mobileWrap = document.querySelector('.portal-mobile .wrap');
  if (!mobileFit || !mobileWrap) return;

  const isMobileLayout = window.matchMedia('(max-width: 900px)').matches;
  if (!isMobileLayout) {
    mobileFit.style.removeProperty('--mobile-fit-scale');
    return;
  }

  mobileFit.style.setProperty('--mobile-fit-scale', '1');
  const availableWidth = mobileWrap.clientWidth;
  const availableHeight = mobileWrap.clientHeight;

  const contentWidth = mobileFit.scrollWidth;
  const contentHeight = mobileFit.scrollHeight;

  if (!contentWidth || !contentHeight) return;

  const scale = Math.min(1, availableWidth / contentWidth, availableHeight / contentHeight);
  mobileFit.style.setProperty('--mobile-fit-scale', String(Math.max(0.65, scale)));
};

let mobileFitTimer = 0;
const scheduleMobileFit = (delayMs) => {
  window.clearTimeout(mobileFitTimer);
  mobileFitTimer = window.setTimeout(applyMobileFit, delayMs);
};

scheduleMobileFit(0);
window.addEventListener('resize', () => scheduleMobileFit(60), { passive: true });
window.addEventListener('orientationchange', () => scheduleMobileFit(250), { passive: true });
window.addEventListener('load', () => scheduleMobileFit(0), { passive: true });
document.fonts?.ready?.then?.(() => scheduleMobileFit(0));

async function copyText(text) {
  try {
    await navigator.clipboard.writeText(text);
    return true;
  } catch {
    try {
      window.prompt('Copy this message:', text);
    } catch {}
    return false;
  }
}

function wireUpdatesForm(opts) {
  const {
    formId, emailId, helperId, helperTextId, openId, copyId, dismissId, source,
  } = opts;

  const form = document.getElementById(formId);
  const helper = document.getElementById(helperId);
  const helperText = document.getElementById(helperTextId);
  const open = document.getElementById(openId);
  const copy = document.getElementById(copyId);
  const dismiss = document.getElementById(dismissId);
  const emailEl = document.getElementById(emailId);

  if (!form || !helper || !helperText || !open || !copy || !dismiss || !emailEl) return;

  let lastCopyText = '';

  form.addEventListener('submit', (e) => {
    e.preventDefault();
    const email = String(emailEl.value ?? '').trim();
    if (!email) {
      helper.hidden = false;
      helperText.textContent = 'Enter your email, then try again.';
      open.setAttribute('href', 'https://ecoamericana.substack.com/s/ephemera');
      lastCopyText = '';
      return;
    }

    const subscribeUrl = 'https://ecoamericana.substack.com/s/ephemera';

    helper.hidden = false;
    helperText.textContent = 'Saving your email...';
    open.setAttribute('href', subscribeUrl);
    lastCopyText = subscribeUrl;

    fetch('/api/updates', {
      method: 'POST',
      headers: { 'content-type': 'application/json' },
      body: JSON.stringify({ email, source }),
    })
      .then(async (res) => {
        if (!res.ok) throw new Error(`HTTP ${res.status}`);
        const data = await res.json().catch(() => ({}));
        const alreadySignedUp = Boolean(data?.alreadySignedUp);
        helper.hidden = false;
        helperText.textContent = alreadySignedUp
          ? 'Already on file.'
          : 'On the list.';
      })
      .catch(() => {
        helper.hidden = false;
        helperText.textContent =
          'Not saved — you can still reach us at the link below.';
      });
  });

  copy.addEventListener('click', async () => {
    if (!lastCopyText) return;
    const ok = await copyText(lastCopyText);
    helper.hidden = false;
    helperText.textContent = ok ? 'Copied Substack link.' : 'Copy dialog opened.';
  });

  dismiss.addEventListener('click', () => {
    helper.hidden = true;
  });
}

wireUpdatesForm({
  formId: 'index-updates-form',
  emailId: 'index-updates-email',
  helperId: 'index-updates-helper',
  helperTextId: 'index-updates-helper-text',
  openId: 'index-updates-open',
  copyId: 'index-updates-copy',
  dismissId: 'index-updates-dismiss',
  source: 'index',
});
</script>

</body>
</html>
