---
import Base from '../layouts/Base.astro';
import siteData from '../data/site.json';

const page = siteData.pages.mission;
const styles = [
  'assets/css/tokens.css',
  'assets/css/interior-base.css',
  'assets/css/layout.css',
  'assets/css/components.css',
  'assets/css/mission.css',
];
---
<Base
  title={page.title}
  description={page.description}
  canonical={page.canonical}
  subtitle={page.subtitle}
  eyebrow={page.eyebrow}
  introKicker={page.introKicker}
  introTitle={page.introTitle}
  introText={page.introText}
  currentNav={page.currentNav}
  styles={styles}
>
  <section class="card mission-copy">
    <p><strong>St. Expedite Press</strong> is a micropress based in New Orleans. We publish books that merit preservation: work with density, consequence, and enough formal integrity to deserve return.</p>
    <p>Publishing here means custodianship rather than throughput. We prefer patient editorial development, careful production, and books that can keep their force after the immediate cycle of release has passed.</p>
    <p>The press remains small on purpose. That scale lets us decide deliberately, work closely, and avoid treating literature like content inventory.</p>
  </section>

  <section class="split-grid">
    <article class="card">
      <h2 class="section-heading">Editorial standards</h2>
      <ul class="check-list principles">
        <li>We favor durable prose, argument, and imagination over trend-chasing novelty.</li>
        <li>We take editing seriously as a form of attention, not as a cosmetic afterthought.</li>
        <li>We prefer clear commitments and explicit standards over vague literary branding.</li>
        <li>We care about the shape of a book as an object as much as the force of the text inside it.</li>
      </ul>
    </article>

    <aside class="card stack">
      <h2 class="section-heading">Use the site by intent</h2>
      <ul class="meta-list">
        <li><strong>Books</strong><br />Use the catalog page for current publications and program status.</li>
        <li><strong>Contact</strong><br />Use general contact for rights, collaborations, press, and editorial questions.</li>
        <li><strong>Submit</strong><br />Use submission inquiries for manuscripts and projects seeking editorial review.</li>
      </ul>
    </aside>
  </section>

  <Fragment slot="scripts">
    <script is:inline src="/assets/js/site-shell.js" type="module"></script>
  </Fragment>
</Base>
