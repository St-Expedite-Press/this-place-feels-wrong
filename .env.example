# St. Expedite Press — environment variable reference
# Copy to .env and fill in real values. Never commit .env.
# Worker secrets (RESEND, STRIPE, FOURTH_WALL) must also be set via
#   wrangler secret put <KEY>  — they are not read from .env at runtime.

## === CLOUDFLARE ===
# Generate at: dash.cloudflare.com/profile/api-tokens
# API token for Wrangler deploys and runtime checks.
# For Pages deploys, the token needs at least Pages Write.
# If reused for Worker deploy/runtime commands, it also needs the existing Worker/D1 permissions.
CLOUDFLARE_API_TOKEN=
# Cloudflare account ID for Pages direct uploads via Wrangler
CLOUDFLARE_ACCOUNT_ID=
# Optional override for npm run deploy:web
CF_PAGES_PROJECT=stexpedite-press

## === RESEND ===
# Transactional email — contact form receipts, submission receipts, donation receipts
# wrangler secret put RESEND_API_KEY
RESEND_API_KEY=

## === STRIPE ===
# Live secret key — Stripe checkout sessions (/api/donate/session)
# wrangler secret put STRIPE_SECRET_KEY
STRIPE_SECRET_KEY=

# Webhook signing secret — /api/stripe/webhook HMAC verification
# Get from: dashboard.stripe.com → Developers → Webhooks → endpoint signing secret
# wrangler secret put STRIPE_WEBHOOK_SECRET
STRIPE_WEBHOOK_SECRET=

## === FOURTHWALL ===
# Storefront API — /api/storefront product catalog
# wrangler secret put FOURTH_WALL_API_KEY
FOURTH_WALL_API_KEY=
FOURTH_WALL_USERNAME=
FOURTH_WALL_PASSWORD=
# HMAC signing key for Fourthwall webhook events
FOURTH_WALL_HMAC=

## === GITHUB ===
# PAT with write access to the St-Expedite-Press org — used by release tooling
GITHUB_PAT_WRITE=
# The target repo for release operations
GITHUB_REPO_URL=https://github.com/St-Expedite-Press/this-place-feels-wrong

## === TELEGRAM (optional) ===
# Bot token for telegram-webhook integration at server.stexpedite.press
TELEGRAM_TOKEN=
TELEGRAM_WEBHOOK_URL=https://server.stexpedite.press/telegram-webhook
